ects/simulyn/server/package.json","path":"/home/smtx724/projects/simulyn/server/package.json","scheme":"file"},"requestId":"request_6a92c4cc-c2b5-4ac4-afa9-16990dacc366","epoch":4,"initialContent":"","telemetryInfo":{}},{"type":"textEdit","uri":{"$mid":1,"fsPath":"/home/smtx724/projects/simulyn/server/package.json","external":"file:///home/smtx724/projects/simulyn/server/package.json","path":"/home/smtx724/projects/simulyn/server/package.json","scheme":"file"},"requestId":"request_6a92c4cc-c2b5-4ac4-afa9-16990dacc366","epoch":5,"edits":[{"text":"{\n  \"name\": \"simulyn-server\",\n  \"version\": \"0.1.0\",\n  \"description\": \"Minimal static server and demo API for Simulyn (development only)\",\n  \"main\": \"index.js\",\n  \"scripts\": {\n    \"start\": \"node server/index.js\",\n    \"stop\": \"lsof -ti tcp:3000 | xargs -r kill || true\"\n  },\n  \"author\": \"\",\n  \"license\": \"MIT\",\n  \"dependencies\": {\n    \"express\": \"^4.18.2\",\n    \"helmet\": \"^6.0.1\",\n    \"express-rate-limit\": \"^6.7.0\",\n    \"cors\": \"^2.8.5\"\n  }\n}\n","range":{"startLineNumber":1,"startColumn":1,"endLineNumber":1,"endColumn":1}}]},{"type":"create","uri":{"$mid":1,"fsPath":"/home/smtx724/projects/simulyn/server/index.js","external":"file:///home/smtx724/projects/simulyn/server/index.js","path":"/home/smtx724/projects/simulyn/server/index.js","scheme":"file"},"requestId":"request_6a92c4cc-c2b5-4ac4-afa9-16990dacc366","epoch":7,"initialContent":"","telemetryInfo":{}},{"type":"textEdit","uri":{"$mid":1,"fsPath":"/home/smtx724/projects/simulyn/server/index.js","external":"file:///home/smtx724/projects/simulyn/server/index.js","path":"/home/smtx724/projects/simulyn/server/index.js","scheme":"file"},"requestId":"request_6a92c4cc-c2b5-4ac4-afa9-16990dacc366","epoch":8,"edits":[{"text":"const path = require('path');\nconst fs = require('fs');\nconst express = require('express');\nconst helmet = require('helmet');\nconst rateLimit = require('express-rate-limit');\nconst cors = require('cors');\n\nconst app = express();\nconst PORT = process.env.PORT || 3000;\n\napp.use(helmet());\napp.use(cors());\napp.use(express.json({ limit: '100kb' }));\n\n// Basic rate limiter\nconst limiter = rateLimit({ windowMs: 1000, max: 20 });\napp.use('/api/', limiter);\n\n// Serve static frontend (project root)\nconst staticRoot = path.join(__dirname, '..');\napp.use(express.static(staticRoot));\n\n// Simple seed data for demo endpoints\nconst seedPath = path.join(__dirname, 'data', 'seed.json');\nlet seed = {};\ntry { seed = JSON.parse(fs.readFileSync(seedPath, 'utf8')); } catch (e) { seed = { hello: 'no-seed' }; }\n\n// Health endpoint\napp.get('/api/health', (req, res) => {\n  res.json({ status: 'ok', time: Date.now() });\n});\n\n// Demo data endpoint\napp.get('/api/demo', (req, res) => {\n  res.json({ status: 'ok', seed: seed });\n});\n\n// Simple login endpoint (demo only) - validates against seed users\napp.post('/api/login', (req, res) => {\n  const { username, password } = req.body || {};\n  if (!username || !password) return res.status(400).json({ error: 'username and password required' });\n  const user = (seed.users || []).find(u => u.username === username && u.password === password);\n  if (!user) return res.status(401).json({ error: 'invalid credentials' });\n  // Return a minimal session token (insecure demo token)\n  return res.json({ token: `demo-token-${user.id}`, user });\n});\n\napp.listen(PORT, () => {\n  console.log(`Simulyn server (dev) listening on http://localhost:${PORT}`);\n});\n","range":{"startLineNumber":1,"startColumn":1,"endLineNumber":1,"endColumn":1}}]},{"type":"create","uri":{"$mid":1,"fsPath":"/home/smtx724/projects/simulyn/server/data/seed.json","external":"file:///home/smtx724/projects/simulyn/server/data/seed.json","path":"/home/smtx724/projects/simulyn/server/data/seed.json","scheme":"file"},"requestId":"request_6a92c4cc-c2b5-4ac4-afa9-16990dacc366","epoch":10,"initialContent":"","telemetryInfo":{}},{"type":"textEdit","uri":{"$mid":1,"fsPath":"/home/smtx724/projects/simulyn/server/data/seed.json","external":"file:///home/smtx724/projects/simulyn/server/data/seed.json","path":"/home/smtx724/projects/simulyn/server/data/seed.json","scheme":"file"},"requestId":"request_6a92c4cc-c2b5-4ac4-afa9-16990dacc366","epoch":11,"edits":[{"text":"{\n  \"users\": [\n    { \"id\": \"u1\", \"username\": \"aditya.sharma\", \"password\": \"student1\", \"role\": \"student\", \"displayName\": \"Aditya Sharma\" },\n    { \"id\": \"t1\", \"username\": \"dr.ramesh\", \"password\": \"teacher1\", \"role\": \"teacher\", \"displayName\": \"Dr. Ramesh Kumar\" }\n  ],\n  \"problems\": [\n    { \"id\": \"p1\", \"title\": \"Two Sum\", \"type\": \"programming\", \"difficulty\": \"easy\", \"points\": 50 }\n  ],\n  \"submissions\": []\n}\n","range":{"startLineNumber":1,"startColumn":1,"endLineNumber":1,"endColumn":1}}]},{"type":"create","uri":{"$mid":1,"fsPath":"/home/smtx724/projects/simulyn/server/Dockerfile","external":"file:///home/smtx724/projects/simulyn/server/Dockerfile","path":"/home/smtx724/projects/simulyn/server/Dockerfile","scheme":"file"},"requestId":"request_21e97f85-8b70-4217-b9ba-ba461632ae94","epoch":16,"initialContent":"","telemetryInfo":{}},{"type":"textEdit","uri":{"$mid":1,"fsPath":"/home/smtx724/projects/simulyn/server/Dockerfile","external":"file:///home/smtx724/projects/simulyn/server/Dockerfile","path":"/home/smtx724/projects/simulyn/server/Dockerfile","scheme":"file"},"requestId":"request_21e97f85-8b70-4217-b9ba-ba461632ae94","epoch":17,"edits":[{"text":"FROM node:20-alpine\n\n# App files\nWORKDIR /app\nCOPY . /app\n\nWORKDIR /app/server\n\n# Install only server deps\nRUN npm install --production --prefix /app/server\n\nEXPOSE 3000\n\nENV NODE_ENV=production\n\nCMD [\"node\", \"index.js\"]\n","range":{"startLineNumber":1,"startColumn":1,"endLineNumber":1,"endColumn":1}}]},{"type":"create","uri":{"$mid":1,"fsPath":"/home/smtx724/projects/simulyn/docker-compose.yml","external":"file:///home/smtx724/projects/simulyn/docker-compose.yml","path":"/home/smtx724/projects/simulyn/docker-compose.yml","scheme":"file"},"requestId":"request_21e97f85-8b70-4217-b9ba-ba461632ae94","epoch":19,"initialContent":"","telemetryInfo":{}},{"type":"textEdit","uri":{"$mid":1,"fsPath":"/home/smtx724/projects/simulyn/docker-compose.yml","external":"file:///home/smtx724/projects/simulyn/docker-compose.yml","path":"/home/smtx724/projects/simulyn/docker-compose.yml","scheme":"file"},"requestId":"request_21e97f85-8b70-4217-b9ba-ba461632ae94","epoch":20,"edits":[{"text":"version: '3.8'\nservices:\n  simulyn:\n    build:\n      context: .\n      dockerfile: server/Dockerfile\n    ports:\n      - \"127.0.0.1:3000:3000\"\n    restart: unless-stopped\n    environment:\n      - NODE_ENV=production\n","range":{"startLineNumber":1,"startColumn":1,"endLineNumber":1,"endColumn":1}}]},{"type":"create","uri":{"$mid":1,"fsPath":"/home/smtx724/projects/simulyn/.dockerignore","external":"file:///home/smtx724/projects/simulyn/.dockerignore","path":"/home/smtx724/projects/simulyn/.dockerignore","scheme":"file"},"requestId":"request_21e97f85-8b70-4217-b9ba-ba461632ae94","epoch":22,"initialContent":"","telemetryInfo":{}},{"type":"textEdit","uri":{"$mid":1,"fsPath":"/home/smtx724/projects/simulyn/.dockerignore","external":"file:///home/smtx724/projects/simulyn/.dockerignore","path":"/home/smtx724/projects/simulyn/.dockerignore","scheme":"file"},"requestId":"request_21e97f85-8b70-4217-b9ba-ba461632ae94","epoch":23,"edits":[{"text":"node_modules\nserver/node_modules\n.git\ndist\ncoverage\n*.log\n","range":{"startLineNumber":1,"startColumn":1,"endLineNumber":1,"endColumn":1}}]},{"type":"create","uri":{"$mid":1,"fsPath":"/home/smtx724/projects/simulyn/server/README.md","external":"file:///home/smtx724/projects/simulyn/server/README.md","path":"/home/smtx724/projects/simulyn/server/README.md","scheme":"file"},"requestId":"request_21e97f85-8b70-4217-b9ba-ba461632ae94","epoch":25,"initialContent":"","telemetryInfo":{}},{"type":"textEdit","uri":{"$mid":1,"fsPath":"/home/smtx724/projects/simulyn/server/README.md","external":"file:///home/smtx724/projects/simulyn/server/README.md","path":"/home/smtx724/projects/simulyn/server/README.md","scheme":"file"},"requestId":"request_21e97f85-8b70-4217-b9ba-ba461632ae94","epoch":26,"edits":[{"text":"# Simulyn dev server (Docker)\n\nThis directory contains a minimal Express server used for local development demo. To run without installing Node/npm locally, use Docker / docker-compose.\n\nBuild and start (docker-compose):\n\n```bash\n# from project root\ndocker compose build\ndocker compose up -d\n```\n\nOpen http://127.0.0.1:3000/\n\nStop and remove:\n\n```bash\ndocker compose down\n```\n\nNotes:\n- This server is for development/demo only. It serves static files from the repository root and exposes simple demo APIs under `/api/*`.\n- Do not use this image for production; replace with a proper API and secure services before deploying.\n","range":{"startLineNumber":1,"startColumn":1,"endLineNumber":1,"endColumn":1}}]}],"epochCounter":28},"recentSnapshot":{"entries":[{"resource":"file:///home/smtx724/projects/simulyn/server/package.json","languageId":"json","originalHash":"92a0cd8","currentHash":"92a0cd8","state":1,"snapshotUri":"chat-editing-snapshot-text-model:/home/smtx724/projects/simulyn/server/package.json?%7B%22session%22%3A%7B%22%24mid%22%3A1%2C%22external%22%3A%22vscode-chat-session%3A%2F%2Flocal%2FNjU1ODJhYzUtYjgyNy00MTI5LTk1NjUtZmUwNTBkOTA2MTE4%22%2C%22path%22%3A%22%2FNjU1ODJhYzUtYjgyNy00MTI5LTk1NjUtZmUwNTBkOTA2MTE4%22%2C%22scheme%22%3A%22vscode-chat-session%22%2C%22authority%22%3A%22local%22%7D%2C%22requestId%22%3A%22%22%2C%22undoStop%22%3A%22%22%7D","telemetryInfo":{"requestId":"request_6a92c4cc-c2b5-4ac4-afa9-16990dacc366","agentId":"github.copilot.editsAgent","modelId":"copilot/auto","modeId":"agent"}},{"resource":"file:///home/smtx724/projects/simulyn/server/index.js","languageId":"javascript","originalHash":"6b8b81d","